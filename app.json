{
  "expo": {
    "name": "Lockmaster AI",
    "slug": "lockmaster-native",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#2B2D42"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.dubiduman.lockmasternative"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon.png",
        "backgroundColor": "#2B2D42"
      },
      "package": "com.dubiduman.lockmasternative"
    },
    "plugins": [
      "@maplibre/maplibre-react-native",
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Lockmaster AI needs location for canal navigation and safety alerts."
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "472ba920-0968-4b88-bf43-aa3018571772"
      }
    }
  }
}
